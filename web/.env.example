# Public canonical origin (used for canonical/hreflang/sitemap absolute URLs)
NEXT_PUBLIC_SITE_URL=https://majstr.xyz

# Backend API base for server-side reads (masters + reference data)
API_BASE=https://api.majstr.xyz

# Existing Vite SPA deployment origin. When set, the Next app multi-zone-rewrites
# the interactive/authed routes (/login, /profile, /admin, /add, /onboard) to it
# so everything stays on the apex domain. Leave empty for a standalone SEO build.
SPA_ORIGIN=

# Shared secret for POST /api/revalidate (set the SAME value in the Telegram bot
# so master approval triggers on-demand ISR).
REVALIDATE_SECRET=
